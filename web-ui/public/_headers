# Cloudflare Pages headers
# This file controls HTTP headers for the deployed site.

# The service worker must not be cached by Cloudflare's edge.
# It also needs Service-Worker-Allowed header to control its scope.
/service-worker.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

# Core PWA files: don't cache these so updates are picked up immediately
/manifest.json
  Cache-Control: no-cache

# HTML files should not be cached at the edge so updates are instant
/*.html
  Cache-Control: no-cache

# Cache static assets at the edge for performance (already cached by SW)
/static/*
  Cache-Control: public, max-age=31536000, immutable